# KDP Unified — Environment Variables
# Copy to .env and fill in your keys

# ─── LLM Providers ────────────────────────────────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-...
OPENAI_API_KEY=sk-...

# ─── Research ─────────────────────────────────────────────────────────────────
# DataForSEO (optional — enables reverse ASIN / search volume)
DATAFORSEO_LOGIN=your@email.com
DATAFORSEO_API_KEY=your_key_here

# ─── Cover / Image Generation ─────────────────────────────────────────────────
# Uses OPENAI_API_KEY for DALL-E (already set above)
# Stability AI (optional)
STABILITY_API_KEY=sk-...

# ─── Audiobook ────────────────────────────────────────────────────────────────
ELEVENLABS_API_KEY=...

# ─── KDP Credentials (for publish automation) ─────────────────────────────────
KDP_EMAIL=your@email.com
KDP_PASSWORD=your_kdp_password
